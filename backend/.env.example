# Backend configuration template — copy to .env and fill in your own values.
# .env is gitignored; this template is committed.

# MongoDB Atlas connection (cluster-scoped, no database in path).
# Get yours from https://cloud.mongodb.com → Connect → Drivers → copy.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Database names (auto-created on first write)
DB_LOKSABHA=loksabha_db
DB_ASSEMBLY=assembly_db
DB_CASTE=caste_db

PORT=5000
# FRONTEND_URL=http://localhost:3000

# Optional — for the Pardhu AI chatbot (Llama 3.3 70B via Groq)
# Sign up free at console.groq.com → API Keys → Create
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
